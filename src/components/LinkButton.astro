---
const { href } = Astro.props;
---

<a
    target="_blank"
    href={href}
    role="link"
    class="inline-flex bg-white/80 text-slate-800 border-cyan-200 items-center justify-center gap-2 px-3 py-2 space-x-2 text-base transition border focus-visible:ring-cyan-400/80 text-md hover:bg-cyan-600 hover:border-cyan-700 group max-w-fit rounded-xl hover:text-white focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-offset-2 active:bg-cyan-800"
>
    <slot />
</a>
